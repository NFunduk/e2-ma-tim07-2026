<?xml version="1.0" encoding="utf-8"?>
<!--
  Drawable za ProgressBar koji prikazuje napredak ka sljedećoj ligi.
  Gradijent: zlatna do ljubičasta (po potrebi promijeniti boje).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pozadina -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="#E0E0E0"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <!-- Sekundarni progress (nije potreban, ali ga Android zahtijeva) -->
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape android:shape="rectangle">
                <solid android:color="#BDBDBD"/>
                <corners android:radius="8dp"/>
            </shape>
        </clip>
    </item>

    <!-- Primarni progress -->
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <gradient
                    android:startColor="#F4C430"
                    android:endColor="#9C27B0"
                    android:angle="0"/>
                <corners android:radius="8dp"/>
            </shape>
        </clip>
    </item>

</layer-list>