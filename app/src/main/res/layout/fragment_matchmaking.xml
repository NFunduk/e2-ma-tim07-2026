<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_blue">

    <ProgressBar
        android:id="@+id/progressBarMatchmaking"
        android:layout_width="64dp"
        android:layout_height="64dp"
        app:layout_constraintBottom_toTopOf="@id/tvMatchmakingStatus"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="20dp"
        android:indeterminateTint="@color/petal" />

    <TextView
        android:id="@+id/tvMatchmakingStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Tražim protivnika..."
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/progressBarMatchmaking"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnCancelMatchmaking"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnCancelMatchmaking"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:text="Otkaži"
        android:textColor="@color/dark_blue"
        android:backgroundTint="@color/petal"
        app:layout_constraintTop_toBottomOf="@id/tvMatchmakingStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
