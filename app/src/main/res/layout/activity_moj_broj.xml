<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mojBrojRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lace">

    <!-- TOP BAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarMojBroj"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="@color/dark_blue"
        android:elevation="10dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:contentInsetStart="0dp"
        app:contentInsetEnd="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moj broj"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />
    </androidx.appcompat.widget.Toolbar>

    <!-- SCROLL CONTENT -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarMojBroj"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header kartica: runda, igrač, tajmer, skor -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/dark_blue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvMojBrojRound"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Runda 1/2"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMojBrojPlayer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Na potezu: igrač 1"
                        android:textColor="@color/lavender"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMojBrojTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="01:00"
                        android:textColor="@color/petal"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMojBrojScore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Igrač 1: 0  |  Igrač 2: 0"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Info poruka -->
            <TextView
                android:id="@+id/tvMojBrojInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/channel_chip_bg"
                android:padding="12dp"
                android:text="Pritisni STOP da vidiš traženi broj."
                android:textColor="@color/dark_blue"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Traženi broj - STOP sekcija -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/dark_blue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TRAŽENI BROJ"
                        android:textColor="@color/lavender"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvTargetNumber"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:text="XXX"
                        android:textColor="@color/white"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btnStopTarget"
                        android:layout_width="160dp"
                        android:layout_height="50dp"
                        android:text="STOP"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_blue"
                        android:backgroundTint="@color/petal" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Ponuđeni brojevi - STOP sekcija -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ponuđeni brojevi"
                        android:textColor="@color/dark_blue"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="10dp" />

                    <!-- Red 1: 3 broja -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tvNum1"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="X"
                            android:textColor="@color/dark_blue"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/filter_unselected_bg" />

                        <TextView
                            android:id="@+id/tvNum2"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="X"
                            android:textColor="@color/dark_blue"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/filter_unselected_bg" />

                        <TextView
                            android:id="@+id/tvNum3"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="X"
                            android:textColor="@color/dark_blue"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/filter_unselected_bg" />
                    </LinearLayout>

                    <!-- Red 2: 3 broja -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvNum4"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="X"
                            android:textColor="@color/dark_blue"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/filter_unselected_bg" />

                        <TextView
                            android:id="@+id/tvNum5"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="X"
                            android:textColor="@color/dark_blue"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/filter_unselected_bg" />

                        <TextView
                            android:id="@+id/tvNum6"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:text="X"
                            android:textColor="@color/dark_blue"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/filter_unselected_bg" />
                    </LinearLayout>

                    <!-- STOP dugme za brojeve -->
                    <Button
                        android:id="@+id/btnStopNumbers"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="STOP — Prikaži brojeve"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_blue"
                        android:backgroundTint="@color/lavender" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Operandi i unos izraza -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/petal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Unesi izraz"
                        android:textColor="@color/dark_blue"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="10dp" />

                    <!-- Operandi dugmad -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="10dp">

                        <Button
                            android:id="@+id/btnOpPlus"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="+"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/blue" />

                        <Button
                            android:id="@+id/btnOpMinus"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="-"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/blue" />

                        <Button
                            android:id="@+id/btnOpMultiply"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="×"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/blue" />

                        <Button
                            android:id="@+id/btnOpDivide"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="÷"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/blue" />

                        <Button
                            android:id="@+id/btnOpOpenParen"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="("
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/dark_blue"
                            android:backgroundTint="@color/lavender" />

                        <Button
                            android:id="@+id/btnOpCloseParen"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text=")"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/dark_blue"
                            android:backgroundTint="@color/lavender" />
                    </LinearLayout>

                    <!-- Polje za unos izraza -->
                    <EditText
                        android:id="@+id/etExpression"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="npr. (25 + 50) * 2 - 3"
                        android:gravity="center"
                        android:textSize="17sp"
                        android:background="@drawable/filter_unselected_bg"
                        android:padding="10dp"
                        android:inputType="none"
                        android:focusable="false" />

                    <!-- Rezultat -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rezultat: "
                            android:textColor="@color/dark_blue"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvResult"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/dark_blue"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Dugmad akcija -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <Button
                            android:id="@+id/btnClearExpression"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Obriši"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/dark_blue" />

                        <Button
                            android:id="@+id/btnSubmitExpression"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="2"
                            android:text="Potvrdi"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/blue" />
                    </LinearLayout>

                    <!-- Sledeća runda dugme -->
                    <Button
                        android:id="@+id/btnMojBrojNext"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:layout_marginTop="6dp"
                        android:text="Sledeća runda"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/dark_blue"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/dark_blue"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:menu="@menu/bottom_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>