<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lace"
    android:padding="12dp">

    <!-- Header kartica: runda, igrač, tajmer, skor -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvKorakRound"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Runda 1/2"
            android:textColor="@color/dark_blue"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvKorakTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01:10"
            android:textColor="@color/dark_blue"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bodovi: "
                android:textColor="@color/dark_blue"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvCurrentPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20"
                android:textColor="@color/dark_blue"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Info poruka -->
    <TextView
        android:id="@+id/tvKorakInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/channel_chip_bg"
        android:padding="8dp"
        android:text="Pogodi pojam na osnovu koraka."
        android:textColor="@color/dark_blue"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- Label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:text="Koraci"
        android:textColor="@color/dark_blue"
        android:textSize="14sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/progressBarKorak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- 7 koraka kao kompaktan grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Korak 1 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:layout_marginBottom="4dp" android:gravity="center_vertical">
            <TextView android:layout_width="28dp" android:layout_height="28dp"
                android:text="1" android:textColor="@color/white" android:textSize="12sp"
                android:textStyle="bold" android:gravity="center"
                android:background="@drawable/filter_selected_bg" />
            <TextView android:id="@+id/tvStep1" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:layout_marginStart="8dp" android:gravity="center"
                android:text="\???" android:textColor="@color/dark_blue"
                android:textSize="13sp" android:textStyle="bold"
                android:background="@drawable/filter_unselected_bg" />
        </LinearLayout>

        <!-- Korak 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:layout_marginBottom="4dp" android:gravity="center_vertical">
            <TextView android:layout_width="28dp" android:layout_height="28dp"
                android:text="2" android:textColor="@color/white" android:textSize="12sp"
                android:textStyle="bold" android:gravity="center"
                android:background="@drawable/filter_selected_bg" />
            <TextView android:id="@+id/tvStep2" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:layout_marginStart="8dp" android:gravity="center"
                android:text="\???" android:textColor="@color/dark_blue"
                android:textSize="13sp" android:textStyle="bold"
                android:background="@drawable/filter_unselected_bg" />
        </LinearLayout>

        <!-- Korak 3 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:layout_marginBottom="4dp" android:gravity="center_vertical">
            <TextView android:layout_width="28dp" android:layout_height="28dp"
                android:text="3" android:textColor="@color/white" android:textSize="12sp"
                android:textStyle="bold" android:gravity="center"
                android:background="@drawable/filter_selected_bg" />
            <TextView android:id="@+id/tvStep3" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:layout_marginStart="8dp" android:gravity="center"
                android:text="\???" android:textColor="@color/dark_blue"
                android:textSize="13sp" android:textStyle="bold"
                android:background="@drawable/filter_unselected_bg" />
        </LinearLayout>

        <!-- Korak 4 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:layout_marginBottom="4dp" android:gravity="center_vertical">
            <TextView android:layout_width="28dp" android:layout_height="28dp"
                android:text="4" android:textColor="@color/white" android:textSize="12sp"
                android:textStyle="bold" android:gravity="center"
                android:background="@drawable/filter_selected_bg" />
            <TextView android:id="@+id/tvStep4" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:layout_marginStart="8dp" android:gravity="center"
                android:text="\???" android:textColor="@color/dark_blue"
                android:textSize="13sp" android:textStyle="bold"
                android:background="@drawable/filter_unselected_bg" />
        </LinearLayout>

        <!-- Korak 5 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:layout_marginBottom="4dp" android:gravity="center_vertical">
            <TextView android:layout_width="28dp" android:layout_height="28dp"
                android:text="5" android:textColor="@color/white" android:textSize="12sp"
                android:textStyle="bold" android:gravity="center"
                android:background="@drawable/filter_selected_bg" />
            <TextView android:id="@+id/tvStep5" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:layout_marginStart="8dp" android:gravity="center"
                android:text="\???" android:textColor="@color/dark_blue"
                android:textSize="13sp" android:textStyle="bold"
                android:background="@drawable/filter_unselected_bg" />
        </LinearLayout>

        <!-- Korak 6 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:layout_marginBottom="4dp" android:gravity="center_vertical">
            <TextView android:layout_width="28dp" android:layout_height="28dp"
                android:text="6" android:textColor="@color/white" android:textSize="12sp"
                android:textStyle="bold" android:gravity="center"
                android:background="@drawable/filter_selected_bg" />
            <TextView android:id="@+id/tvStep6" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:layout_marginStart="8dp" android:gravity="center"
                android:text="\???" android:textColor="@color/dark_blue"
                android:textSize="13sp" android:textStyle="bold"
                android:background="@drawable/filter_unselected_bg" />
        </LinearLayout>

        <!-- Korak 7 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView android:layout_width="28dp" android:layout_height="28dp"
                android:text="7" android:textColor="@color/white" android:textSize="12sp"
                android:textStyle="bold" android:gravity="center"
                android:background="@drawable/filter_selected_bg" />
            <TextView android:id="@+id/tvStep7" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:layout_marginStart="8dp" android:gravity="center"
                android:text="\???" android:textColor="@color/dark_blue"
                android:textSize="13sp" android:textStyle="bold"
                android:background="@drawable/filter_unselected_bg" />
        </LinearLayout>

    </LinearLayout>

    <!-- Input za odgovor -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/petal">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etKorakAnswer"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Unesi pojam..."
                android:gravity="center"
                android:textSize="15sp"
                android:textColor="@color/dark_blue"
                android:background="@drawable/filter_unselected_bg"
                android:padding="10dp"
                android:inputType="text" />

            <Button
                android:id="@+id/btnKorakGuess"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:text="Pogodi"
                android:backgroundTint="@color/blue"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>