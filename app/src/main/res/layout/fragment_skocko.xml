<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/skockoRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lace">


    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp">

            <!-- HEADER ISTI KAO KORAK PO KORAK -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tvSkockoRound"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Runda 1/2"
                    android:textColor="@color/dark_blue"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSkockoTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:30"
                    android:textColor="@color/dark_blue"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvSkockoPlayer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Na potezu: igrač 1"
                        android:textColor="@color/dark_blue"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSkockoScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 : 0"
                        android:textColor="@color/dark_blue"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tvSkockoInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/channel_chip_bg"
                android:padding="8dp"
                android:gravity="center"
                android:textSize="13sp"
                android:text="Izaberi 4 znaka i proveri kombinaciju."
                android:textColor="@color/dark_blue"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/attemptsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical">

                <TextView android:id="@+id/row1" style="@style/SkockoRowText" />
                <TextView android:id="@+id/row2" style="@style/SkockoRowText" />
                <TextView android:id="@+id/row3" style="@style/SkockoRowText" />
                <TextView android:id="@+id/row4" style="@style/SkockoRowText" />
                <TextView android:id="@+id/row5" style="@style/SkockoRowText" />
                <TextView android:id="@+id/row6" style="@style/SkockoRowText" />
            </LinearLayout>

            <TextView
                android:id="@+id/currentGuess"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:minHeight="70dp"
                android:maxHeight="70dp"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="_  _  _  _"
                android:textColor="@color/dark_blue"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@drawable/filter_unselected_bg" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/symbol1"
                    style="@style/SkockoSymbolButton"
                    android:src="@drawable/ic_skocko" />

                <ImageButton
                    android:id="@+id/symbol2"
                    style="@style/SkockoSymbolButton"
                    android:src="@drawable/ic_square" />

                <ImageButton
                    android:id="@+id/symbol3"
                    style="@style/SkockoSymbolButton"
                    android:src="@drawable/ic_circle" />

                <ImageButton
                    android:id="@+id/symbol4"
                    style="@style/SkockoSymbolButton"
                    android:src="@drawable/ic_heart" />

                <ImageButton
                    android:id="@+id/symbol5"
                    style="@style/SkockoSymbolButton"
                    android:src="@drawable/ic_triangle" />

                <ImageButton
                    android:id="@+id/symbol6"
                    style="@style/SkockoSymbolButton"
                    android:src="@drawable/ic_star" />
            </LinearLayout>

            <Button
                android:id="@+id/btnCheck"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="12dp"
                android:text="Proveri"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:backgroundTint="@color/blue" />

            <Button
                android:id="@+id/btnClear"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="8dp"
                android:text="Obriši unos"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:backgroundTint="@color/dark_blue" />

            <Button
                android:id="@+id/btnNextSkocko"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="8dp"
                android:text="Sledeća runda"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:backgroundTint="@color/dark_blue"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>