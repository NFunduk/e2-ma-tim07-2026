<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp" android:background="@drawable/filter_unselected_bg" android:layout_marginBottom="8dp">
    <!--  Avatar + online indikator  -->
    <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:layout_marginEnd="12dp">
        <ImageView android:id="@+id/ivFriendAvatar" android:layout_width="44dp" android:layout_height="44dp" android:src="@drawable/outline_account_circle_24" android:background="@drawable/avatar_bg_circle" android:scaleType="centerInside" android:padding="4dp"/>
        <ImageView android:id="@+id/ivFriendOnlineDot" android:layout_width="12dp" android:layout_height="12dp" android:layout_gravity="bottom|end" android:src="@drawable/dot_offline"/>
    </FrameLayout>
    <!--  Tekstualni podaci  -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvFriendUsername" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Username" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/dark_blue"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
            <TextView android:id="@+id/tvFriendStars" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 ⭐" android:textSize="12sp" android:textColor="#555555" android:layout_marginEnd="10dp"/>
            <TextView android:id="@+id/tvFriendLeague" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Liga 0" android:textSize="12sp" android:textColor="#555555" android:layout_marginEnd="10dp"/>
            <TextView android:id="@+id/tvFriendRank" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bez ranga" android:textSize="12sp" android:textColor="#555555"/>
        </LinearLayout>
    </LinearLayout>
    <!--  Dugme za akciju (Pozovi / Dodaj)  -->
    <ImageButton android:id="@+id/btnFriendAction" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/baseline_play_arrow_24" android:background="@drawable/avatar_bg_circle" android:padding="6dp" android:contentDescription="Akcija"/>
</LinearLayout>