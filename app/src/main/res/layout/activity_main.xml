<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lace"
    tools:context=".MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/navHostFragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:navGraph="@navigation/app_nav"
        app:defaultNavHost="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:background="@drawable/top_bar_bg"
        android:elevation="10dp"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        app:contentInsetEnd="0dp"
        app:contentInsetStart="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- ZAMENI unutrašnji LinearLayout toolbara sa ovim: -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- === NORMALNI MOD (sakrij tokom igre) === -->
            <LinearLayout
                android:id="@+id/layoutToolbarNormal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginTop="6dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvToolbarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.05"
                    android:text="SaBoNa"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- === GAME MOD (prikaži tokom igre) === -->
            <LinearLayout
                android:id="@+id/layoutToolbarGame"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Ime igre sitno -->
                <TextView
                    android:id="@+id/tvGameName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ko zna zna"
                    android:textColor="@color/lavender"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true" />

                <!-- Igrači i bodovi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">

                    <!-- Igrač 1 -->
                    <ImageView
                        android:id="@+id/ivPlayer1Avatar"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/outline_account_circle_24"
                        android:background="@drawable/profile_circle_bg"
                        android:padding="2dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="5dp">

                        <TextView
                            android:id="@+id/tvPlayer1Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Igrač 1"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:maxWidth="85dp"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/tvPlayer1Score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 bod"
                            android:textColor="@color/petal"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvMatchScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 : 0"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/layoutMiniStats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="9dp"
                                android:layout_height="9dp"
                                android:src="@drawable/star"
                                app:tint="@color/petal"/>

                            <TextView
                                android:id="@+id/tvStars"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="120"
                                android:textSize="8sp"
                                android:textColor="@color/lavender"/>

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/outline_capture_24"
                                app:tint="@color/petal"/>

                            <TextView
                                android:id="@+id/tvTokens"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5"
                                android:textSize="9sp"
                                android:textColor="@color/lavender"/>

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/outline_atr_24"
                                app:tint="@color/petal"/>

                            <TextView
                                android:id="@+id/tvLeague"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Liga 3"
                                android:textSize="9sp"
                                android:textColor="@color/lavender"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Igrač 2 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end"
                        android:layout_marginEnd="5dp">

                        <TextView
                            android:id="@+id/tvPlayer2Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Igrač 2"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:maxWidth="85dp"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/tvPlayer2Score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 bod"
                            android:textColor="@color/petal"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivPlayer2Avatar"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:src="@drawable/outline_account_circle_24"
                        android:background="@drawable/profile_circle_bg"
                        android:padding="2dp" />

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutStatsChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/stats_chip_bg"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:src="@drawable/star"
                    app:tint="@color/petal" />

                <TextView
                    android:id="@+id/tvStarsChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="120"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:layout_marginStart="13dp"
                    android:src="@drawable/outline_capture_24"
                    app:tint="@color/petal" />

                <TextView
                    android:id="@+id/tvTokensChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="5"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:layout_marginStart="13dp"
                    android:src="@drawable/outline_atr_24"
                    app:tint="@color/petal" />

                <TextView
                    android:id="@+id/tvLeagueChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="Liga 3"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>


            <ImageView
                android:id="@+id/btnNotifications"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="6dp"
                android:layout_gravity="top"
                android:background="@drawable/profile_circle_bg"
                android:padding="4dp"
                android:src="@drawable/outline_notifications_24"
                app:tint="@color/dark_blue" />

        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dark_blue"
        app:menu="@menu/bottom_menu"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>