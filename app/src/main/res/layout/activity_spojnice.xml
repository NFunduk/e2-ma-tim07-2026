<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/spojniceRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lace">

    <!-- TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarSpojnice"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="@color/dark_blue"
        android:elevation="10dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:contentInsetStart="0dp"
        app:contentInsetEnd="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spojnice"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />
    </androidx.appcompat.widget.Toolbar>

    <!-- SCROLL CONTENT -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarSpojnice"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- HEADER KARTICA: runda, igrac, timer, score -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/dark_blue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvRound"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Runda 1/2"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPlayer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Na potezu: Igrač 1"
                        android:textColor="@color/lavender"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="00:30"
                        android:textColor="@color/petal"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvScore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Igrač 1: 0  |  Igrač 2: 0"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- INFO PORUKA -->
            <TextView
                android:id="@+id/tvInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/channel_chip_bg"
                android:padding="12dp"
                android:text="Klikni na pojam lijevo, pa na odgovarajući pojam desno."
                android:textColor="@color/dark_blue"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- KRITERIJUM -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/petal">

                <TextView
                    android:id="@+id/tvCriteria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:gravity="center"
                    android:text="Povežite izvođače sa njihovim pjesmama"
                    android:textColor="@color/dark_blue"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <!-- TABELA SPOJNICA: lijeva kolona + desna kolona -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <!-- LIJEVA KOLONA - pojmovi -->
                <LinearLayout
                    android:id="@+id/leftColumn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/btnLeft1"
                        style="@style/SpojniceLeftButton"
                        android:text="Pojam 1" />

                    <Button
                        android:id="@+id/btnLeft2"
                        style="@style/SpojniceLeftButton"
                        android:text="Pojam 2" />

                    <Button
                        android:id="@+id/btnLeft3"
                        style="@style/SpojniceLeftButton"
                        android:text="Pojam 3" />

                    <Button
                        android:id="@+id/btnLeft4"
                        style="@style/SpojniceLeftButton"
                        android:text="Pojam 4" />

                    <Button
                        android:id="@+id/btnLeft5"
                        style="@style/SpojniceLeftButton"
                        android:text="Pojam 5" />

                </LinearLayout>

                <!-- SREDINA - strelice/status -->
                <LinearLayout
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvArrow1"
                        style="@style/SpojniceArrow"
                        android:text="→" />

                    <TextView
                        android:id="@+id/tvArrow2"
                        style="@style/SpojniceArrow"
                        android:text="→" />

                    <TextView
                        android:id="@+id/tvArrow3"
                        style="@style/SpojniceArrow"
                        android:text="→" />

                    <TextView
                        android:id="@+id/tvArrow4"
                        style="@style/SpojniceArrow"
                        android:text="→" />

                    <TextView
                        android:id="@+id/tvArrow5"
                        style="@style/SpojniceArrow"
                        android:text="→" />

                </LinearLayout>

                <!-- DESNA KOLONA - parovi -->
                <LinearLayout
                    android:id="@+id/rightColumn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/btnRight1"
                        style="@style/SpojniceRightButton"
                        android:text="Par 1" />

                    <Button
                        android:id="@+id/btnRight2"
                        style="@style/SpojniceRightButton"
                        android:text="Par 2" />

                    <Button
                        android:id="@+id/btnRight3"
                        style="@style/SpojniceRightButton"
                        android:text="Par 3" />

                    <Button
                        android:id="@+id/btnRight4"
                        style="@style/SpojniceRightButton"
                        android:text="Par 4" />

                    <Button
                        android:id="@+id/btnRight5"
                        style="@style/SpojniceRightButton"
                        android:text="Par 5" />

                </LinearLayout>
            </LinearLayout>

            <!-- BODOVI PO PARU - prikaz rezultata -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <!-- Igrač 1 bodovi za rundu -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Igrač 1"
                            android:textColor="@color/dark_blue"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvRoundScore1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 bod."
                            android:textColor="@color/blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/lavender" />

                    <!-- Tačno spojeno -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvConnected"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/5"
                            android:textColor="@color/dark_blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="spojeno"
                            android:textColor="@color/dark_blue"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/lavender" />

                    <!-- Igrač 2 bodovi za rundu -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Igrač 2"
                            android:textColor="@color/dark_blue"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvRoundScore2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 bod."
                            android:textColor="@color/blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- DUGME DALJE / SLJEDECA RUNDA -->
            <Button
                android:id="@+id/btnNextRound"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:text="Dalje →"
                android:backgroundTint="@color/dark_blue"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/dark_blue"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:menu="@menu/bottom_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>