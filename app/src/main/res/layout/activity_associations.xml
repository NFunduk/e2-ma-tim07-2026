<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/associationsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lace">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarAssociations"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="@color/dark_blue"
        android:elevation="10dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:contentInsetStart="0dp"
        app:contentInsetEnd="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Asocijacije"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarAssociations"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/dark_blue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvRound"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Runda 1/2"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPlayer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Na potezu: igrač 1"
                        android:textColor="@color/lavender"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="02:00"
                        android:textColor="@color/petal"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvScore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Igrač 1: 0 | Igrač 2: 0"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/channel_chip_bg"
                android:padding="12dp"
                android:text="Otvori polje ili pogodi rešenje."
                android:textColor="@color/dark_blue"
                android:textSize="14sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- KOLONA A -->
                    <LinearLayout
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="A"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:background="@color/dark_blue" />

                        <Button android:id="@+id/a1" style="@style/AssociationFieldButton" android:text="?" />
                        <Button android:id="@+id/a2" style="@style/AssociationFieldButton" android:text="?" />
                        <Button android:id="@+id/a3" style="@style/AssociationFieldButton" android:text="?" />
                        <Button android:id="@+id/a4" style="@style/AssociationFieldButton" android:text="?" />

                        <TextView
                            android:id="@+id/solutionA"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:gravity="center"
                            android:text="?"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:background="@color/blue" />

                        <EditText
                            android:id="@+id/inputA"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Rešenje A"
                            android:textSize="13sp"
                            android:padding="8dp" />

                        <Button
                            android:id="@+id/btnGuessA"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="Pogodi A"
                            android:textSize="12sp"
                            android:backgroundTint="@color/dark_blue"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <!-- KOLONA B -->
                    <LinearLayout
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="B"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:background="@color/dark_blue" />

                        <Button android:id="@+id/b1" style="@style/AssociationFieldButton" android:text="?" />
                        <Button android:id="@+id/b2" style="@style/AssociationFieldButton" android:text="?" />
                        <Button android:id="@+id/b3" style="@style/AssociationFieldButton" android:text="?" />
                        <Button android:id="@+id/b4" style="@style/AssociationFieldButton" android:text="?" />

                        <TextView
                            android:id="@+id/solutionB"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:gravity="center"
                            android:text="?"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:background="@color/blue" />

                        <EditText
                            android:id="@+id/inputB"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Rešenje B"
                            android:textSize="13sp"
                            android:padding="8dp" />

                        <Button
                            android:id="@+id/btnGuessB"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="Pogodi B"
                            android:textSize="12sp"
                            android:backgroundTint="@color/dark_blue"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <!-- KOLONA C -->
                    <LinearLayout
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="C"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:background="@color/dark_blue" />

                        <Button android:id="@+id/c1" style="@style/AssociationFieldButton" android:text="?" />
                        <Button android:id="@+id/c2" style="@style/AssociationFieldButton" android:text="?" />
                        <Button android:id="@+id/c3" style="@style/AssociationFieldButton" android:text="?" />
                        <Button android:id="@+id/c4" style="@style/AssociationFieldButton" android:text="?" />

                        <TextView
                            android:id="@+id/solutionC"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:gravity="center"
                            android:text="?"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:background="@color/blue" />

                        <EditText
                            android:id="@+id/inputC"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Rešenje C"
                            android:textSize="13sp"
                            android:padding="8dp" />

                        <Button
                            android:id="@+id/btnGuessC"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="Pogodi C"
                            android:textSize="12sp"
                            android:backgroundTint="@color/dark_blue"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <!-- KOLONA D -->
                    <LinearLayout
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:gravity="center"
                            android:text="D"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:background="@color/dark_blue" />

                        <Button android:id="@+id/d1" style="@style/AssociationFieldButton" android:text="?" />
                        <Button android:id="@+id/d2" style="@style/AssociationFieldButton" android:text="?" />
                        <Button android:id="@+id/d3" style="@style/AssociationFieldButton" android:text="?" />
                        <Button android:id="@+id/d4" style="@style/AssociationFieldButton" android:text="?" />

                        <TextView
                            android:id="@+id/solutionD"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:gravity="center"
                            android:text="?"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:background="@color/blue" />

                        <EditText
                            android:id="@+id/inputD"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Rešenje D"
                            android:textSize="13sp"
                            android:padding="8dp" />

                        <Button
                            android:id="@+id/btnGuessD"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="Pogodi D"
                            android:textSize="12sp"
                            android:backgroundTint="@color/dark_blue"
                            android:textColor="@color/white" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/petal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Konačno rešenje"
                        android:textColor="@color/dark_blue"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/inputFinal"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:hint="Unesi konačno rešenje"
                        android:padding="10dp"
                        android:textSize="15sp" />

                    <Button
                        android:id="@+id/btnGuessFinal"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="Pogodi konačno rešenje"
                        android:backgroundTint="@color/blue"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnNextRound"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="Sledeća runda"
                        android:backgroundTint="@color/dark_blue"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>