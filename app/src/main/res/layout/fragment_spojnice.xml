<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/spojniceRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lace">

    <!-- SCROLL CONTENT -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- HEADER ISTI KAO KORAK PO KORAK -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tvRound"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Runda 1/2"
                    android:textColor="@color/dark_blue"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:30"
                    android:textColor="@color/dark_blue"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvPlayer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Na potezu: Igrač 1"
                        android:textColor="@color/dark_blue"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 : 0"
                        android:textColor="@color/dark_blue"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- INFO PORUKA -->
            <TextView
                android:id="@+id/tvInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/channel_chip_bg"
                android:padding="8dp"
                android:text="Klikni na pojam lijevo, pa na odgovarajući pojam desno."
                android:textColor="@color/dark_blue"
                android:textSize="13sp"
                android:gravity="center"
                android:textStyle="bold" />

            <!-- KRITERIJUM -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/petal">

                <TextView
                    android:id="@+id/tvCriteria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:gravity="center"
                    android:text="Povežite izvođače sa njihovim pjesmama"
                    android:textColor="@color/dark_blue"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <!-- TABELA SPOJNICA: lijeva kolona + desna kolona -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <!-- LIJEVA KOLONA -->
                <LinearLayout
                    android:id="@+id/leftColumn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/btnLeft1"
                        style="@style/SpojniceLeftButton"
                        android:text="Pojam 1" />

                    <Button
                        android:id="@+id/btnLeft2"
                        style="@style/SpojniceLeftButton"
                        android:text="Pojam 2" />

                    <Button
                        android:id="@+id/btnLeft3"
                        style="@style/SpojniceLeftButton"
                        android:text="Pojam 3" />

                    <Button
                        android:id="@+id/btnLeft4"
                        style="@style/SpojniceLeftButton"
                        android:text="Pojam 4" />

                    <Button
                        android:id="@+id/btnLeft5"
                        style="@style/SpojniceLeftButton"
                        android:text="Pojam 5" />

                </LinearLayout>

                <!-- SREDINA - strelice -->
                <LinearLayout
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvArrow1"
                        style="@style/SpojniceArrow"
                        android:text="→" />

                    <TextView
                        android:id="@+id/tvArrow2"
                        style="@style/SpojniceArrow"
                        android:text="→" />

                    <TextView
                        android:id="@+id/tvArrow3"
                        style="@style/SpojniceArrow"
                        android:text="→" />

                    <TextView
                        android:id="@+id/tvArrow4"
                        style="@style/SpojniceArrow"
                        android:text="→" />

                    <TextView
                        android:id="@+id/tvArrow5"
                        style="@style/SpojniceArrow"
                        android:text="→" />

                </LinearLayout>

                <!-- DESNA KOLONA -->
                <LinearLayout
                    android:id="@+id/rightColumn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/btnRight1"
                        style="@style/SpojniceRightButton"
                        android:text="Par 1" />

                    <Button
                        android:id="@+id/btnRight2"
                        style="@style/SpojniceRightButton"
                        android:text="Par 2" />

                    <Button
                        android:id="@+id/btnRight3"
                        style="@style/SpojniceRightButton"
                        android:text="Par 3" />

                    <Button
                        android:id="@+id/btnRight4"
                        style="@style/SpojniceRightButton"
                        android:text="Par 4" />

                    <Button
                        android:id="@+id/btnRight5"
                        style="@style/SpojniceRightButton"
                        android:text="Par 5" />

                </LinearLayout>
            </LinearLayout>



            <!-- DUGME DALJE (skriveno, automatski prelaz) -->
            <Button
                android:id="@+id/btnNextRound"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:text="Dalje →"
                android:backgroundTint="@color/dark_blue"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>